---
import "../../styles/global.css";
import Layout from "../../layouts/BaseLayout.astro";
import IconRobotFace from "../../components/icons/IconRobotFace.astro";

const title = "Videojuegos con Roblox Studio";
const description =
  "Curso virtual de desarrollo de videojuegos para chicos de 8 a 13 años. Creá mapas, desafíos y juegos en Roblox Studio mientras aprendés programación, lógica y creatividad de forma divertida.";

const ctaLink = "https://wa.me/+5492324468366";
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section
    class="py-20 px-6 text-center bg-gradient-to-b from-[var(--color-bg)] to-[var(--color-bg-secondary)] text-[var(--color-text)]"
  >
    <div class="max-w-3xl mx-auto">
      <div class="flex justify-center mb-6">
        <IconRobotFace
          class="w-20 h-20 text-[var(--color-primary)] drop-shadow-lg"
        />
      </div>

      <h1
        class="text-4xl sm:text-5xl font-title font-extrabold mb-4 leading-tight"
      >
        {title}
      </h1>

      <p class="text-lg max-w-2xl mx-auto mb-8 leading-relaxed">
        Explorá el mundo del desarrollo de videojuegos con Roblox Studio de
        forma virtual y divertida. Creá tus propios mapas y juegos mientras
        desarrollás creatividad, lógica y pensamiento computacional.
      </p>

      <p
        class="inline-block text-sm uppercase tracking-wide font-semibold text-[var(--color-primary)] bg-[var(--color-primary)]/10 px-4 py-2 rounded-full mb-8"
      >
        Curso virtual · 8 a 13 años
      </p>

      <div>
        <a
          href={ctaLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-10 py-4 rounded-full font-bold text-white bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] transition duration-300 shadow-lg hover:shadow-xl hover:scale-105"
        >
          Inscribirme
        </a>
      </div>
    </div>
  </section>

  <!-- Contenidos -->
  <section class="py-20 px-6 max-w-4xl mx-auto text-[var(--color-text)]">
    <h2 class="text-3xl font-bold mb-6 text-center font-title">
      ¿Qué aprenden en este curso?
    </h2>

    <ul
      class="list-disc list-inside space-y-3 text-lg leading-relaxed max-w-2xl mx-auto"
    >
      <li>Diseño y creación de mundos en Roblox Studio.</li>
      <li>Programación básica aplicada a videojuegos.</li>
      <li>Desarrollo de desafíos y mecánicas de juego.</li>
      <li>Creatividad, resolución de problemas y trabajo en equipo.</li>
      <li>
        Clases virtuales en vivo con profesor acompañando cada proyecto.
      </li>
    </ul>
  </section>

  <!-- Proyecto principal -->
  <section class="py-20 px-6 bg-[var(--glass-bg)] backdrop-blur-md">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-8 font-title">
      Lo que pueden crear
    </h2>

    <div class="max-w-5xl mx-auto">
      <img
        src="/assets/img/proyectos/roblox/roblox-studio.webp"
        alt="Proyecto realizado en Roblox Studio"
        class="rounded-2xl shadow-xl w-full border border-[var(--color-border)]"
        loading="lazy"
      />
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-6 max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold mb-8 text-center font-title">
      Preguntas frecuentes
    </h2>

    <div class="space-y-5">
      <details
        class="p-5 rounded-xl border border-[var(--color-border)] bg-[var(--glass-bg)] backdrop-blur transition duration-300"
      >
        <summary class="cursor-pointer font-semibold">
          ¿Hace falta saber programación?
        </summary>

        <p class="mt-2 text-base leading-relaxed">
          No. El curso está pensado para aprender desde cero mientras crean
          proyectos divertidos dentro de Roblox Studio.
        </p>
      </details>

      <details
        class="p-5 rounded-xl border border-[var(--color-border)] bg-[var(--glass-bg)] backdrop-blur transition duration-300"
      >
        <summary class="cursor-pointer font-semibold">
          ¿Las clases son virtuales?
        </summary>

        <p class="mt-2 text-base leading-relaxed">
          Sí. Las clases se realizan en vivo de manera virtual con
          acompañamiento constante del profesor durante cada proyecto.
        </p>
      </details>

      <details
        class="p-5 rounded-xl border border-[var(--color-border)] bg-[var(--glass-bg)] backdrop-blur transition duration-300"
      >
        <summary class="cursor-pointer font-semibold">
          ¿Qué computadora necesito?
        </summary>

        <p class="mt-2 text-base leading-relaxed">
          Se recomienda una computadora o notebook con conexión a internet capaz
          de ejecutar Roblox Studio correctamente.
        </p>
      </details>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-20 px-6 text-center">
    <h2 class="text-3xl font-bold mb-6 font-title">
      ¡Creá tu propio videojuego!
    </h2>

    <a
      href={ctaLink}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block px-10 py-4 rounded-full font-bold text-white bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] transition duration-300 shadow-lg hover:shadow-xl hover:scale-105"
    >
      Inscribirme ahora
    </a>
  </section>
</Layout>