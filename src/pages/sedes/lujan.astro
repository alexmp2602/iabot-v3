---
import Layout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";

const title = "Sede Luján | IABOT Robótica Educativa";
const description =
  "Descubrí nuestra sede en Luján. Clases de robótica con LEGO, programación creativa y capacitación docente para todas las edades.";
const ctaLink = "https://wa.me/+5492324468366";
---

<Layout title={title} description={description}>
  <section
    class="py-20 px-6 text-center bg-[var(--color-lujan)] text-[var(--color-text)]"
  >
    <h1
      class="text-4xl sm:text-5xl font-title font-bold mb-4 animate-fade-in-up"
    >
      Sede Luján
    </h1>
    <p class="text-lg max-w-2xl mx-auto mb-8 animate-fade-in-up">
      Brindamos un espacio donde niños y niñas pueden aprender y desarrollar
      robótica y programación educativa con nuestros kits innovadores, en grupos
      reducidos y con atención personalizada. Clases 100% prácticas en un
      entorno creativo y colaborativo.
    </p>

    <!-- CTA -->
    <a
      href={ctaLink}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block px-8 py-4 rounded-full font-semibold text-white bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] transition-all duration-300 shadow-md hover:shadow-lg hover:scale-105 animate-fade-in-up"
    >
      Consultar o Inscribirme
    </a>

    <!-- Mapa -->
    <div
      class="w-full max-w-4xl mx-auto h-[300px] sm:h-[400px] lg:h-[450px] rounded-xl overflow-hidden shadow-md mt-12 animate-fade-in-up"
    >
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3285.414001700645!2d-59.121837925214905!3d-34.568389655631705!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bc7d931a1ee53b%3A0x3fbf632e967c3aa6!2sItuzaing%C3%B3%20315%2C%20B6700%20AVG%2C%20Provincia%20de%20Buenos%20Aires!5e0!3m2!1ses-419!2sar!4v1771728311429!5m2!1ses-419!2sar"
        class="w-full h-full border-0"
        width="800"
        height="600"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </section>
</Layout>
